#!/usr/bin/env bash
set -euo pipefail

# Git commit-msg hook - Remove AI attribution
# Install: ln -sf ../../hooks/commit-msg .git/hooks/commit-msg

COMMIT_MSG_FILE="$1"

# Remove AI attribution automatically
sed -i.bak '/Generated with.*Claude Code/d' "$COMMIT_MSG_FILE"
sed -i.bak '/Co-Authored-By:.*Claude/d' "$COMMIT_MSG_FILE"
sed -i.bak '/Co-Authored-By:.*Copilot/d' "$COMMIT_MSG_FILE"
sed -i.bak '/Co-Authored-By:.*Cursor/d' "$COMMIT_MSG_FILE"
sed -i.bak '/Assisted by.*/d' "$COMMIT_MSG_FILE"

# Clean up backup file
rm -f "${COMMIT_MSG_FILE}.bak"

exit 0
