#!/usr/bin/env bash
# Project:      HyperSec AI
# File:         hooks/pre-commit
# Purpose:      Validates branch name and detects AI changes
# License:      LicenseRef-HyperSec-EULA
# Copyright:    (c) 2025 HyperSec Pty Ltd
#
# Installed by: ./ai/attach.sh

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

# Extract branch name, handling both "main" and "heads/main" formats
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null | sed 's|^heads/||' || echo "")

# Skip validation for trunk branches and detached HEAD
if [[ -z "$CURRENT_BRANCH" ]] || [[ "$CURRENT_BRANCH" =~ ^(main|master|develop|HEAD)$ ]]; then
    exit 0
fi

# Validate branch name format: type/issue-ref/description
# Examples: fix/no-ref/bug-name, feat/AI-123/new-feature, docs/no-ref/update

VALID_TYPES="feat|fix|docs|test|chore|ci|cleanup|data|debt|design|infra|meta|ops|perf|refactor|review|sec|spike|ui|hotfix"
BRANCH_PATTERN="^(${VALID_TYPES})/([A-Z]+-[0-9]+|no-ref)/[a-z0-9-]+$"

if [[ ! "$CURRENT_BRANCH" =~ $BRANCH_PATTERN ]]; then
    echo ""
    echo "Invalid branch name: $CURRENT_BRANCH"
    echo ""
    echo "Branch must follow format: <type>/<issue-ref>/<description>"
    echo ""
    echo "Examples:"
    echo "  fix/no-ref/missing-template"
    echo "  feat/AI-123/add-cursor-support"
    echo "  docs/no-ref/update-readme"
    echo ""
    echo "Valid types: feat, fix, docs, test, chore, ci, perf, etc."
    echo "Issue ref: Use ticket ID (e.g., AI-123) or 'no-ref'"
    echo "Description: Lowercase with hyphens (e.g., add-new-feature)"
    echo ""
    echo "See: ai/standards/common/GIT-WORKFLOW.md"
    echo ""
    exit 1
fi

# Detect AI directory modifications (informational only)
if git diff --cached --name-only | grep -q "^ai/"; then
    echo "AI directory changes detected:"
    git diff --cached --name-only | grep "^ai/" | sed 's/^/    /'
    echo ""
fi

exit 0
