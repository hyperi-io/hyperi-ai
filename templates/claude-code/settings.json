{
  "includeCoAuthoredBy": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "enabledPlugins": {
    "docker": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/hyperi-ai/hooks/inject_standards.py\"",
            "statusMessage": "Loading coding standards..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/hyperi-ai/hooks/on_compact.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/hyperi-ai/hooks/auto_format.py\"",
            "statusMessage": "Formatting..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/hyperi-ai/hooks/subagent_context.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/hyperi-ai/hooks/safety_guard.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/hyperi-ai/hooks/lint_check.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob",
      "Grep",
      "LS",
      "Search",
      "Find",
      "SlashCommand(/load)",
      "SlashCommand(/save)",
      "SlashCommand(/review)",
      "SlashCommand(/simplify)",
      "SlashCommand(/standards)",
      "SlashCommand(/setup-claude)",
      "Read(~/.gitconfig)",

      "Bash(.tmp/*)",
      "Bash(./.tmp/*)",
      "Bash(mkdir -p .tmp)",
      "Bash(mkdir .tmp *)",
      "Bash(rm .tmp/*)",
      "Bash(rm -f .tmp/*)",
      "Bash(rm -rf .tmp/*)",
      "Bash(rm -rf .tmp)",
      "Bash(chmod +x .tmp/*)",
      "Bash(sh .tmp/*)",
      "Bash(bash .tmp/*)",
      "Bash(python .tmp/*)",
      "Bash(python3 .tmp/*)",
      "Bash(node .tmp/*)",
      "Bash(source .tmp/*)",
      "Bash(. .tmp/*)",
      "Bash(cat .tmp/*)",
      "Bash(head .tmp/*)",
      "Bash(tail .tmp/*)",
      "Bash(sort .tmp/*)",
      "Bash(uniq .tmp/*)",
      "Bash(wc .tmp/*)",
      "Bash(diff .tmp/*)",
      "Bash(comm .tmp/*)",
      "Bash(paste .tmp/*)",
      "Bash(column .tmp/*)",
      "Bash(nl .tmp/*)",
      "Bash(tee .tmp/*)",
      "Bash(cp .tmp/*)",
      "Bash(mv .tmp/*)",

