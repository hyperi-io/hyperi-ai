{
  "model": "gemini-3-pro-preview",
  "contextWindow": 1000000,
  "temperature": 0.7,
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob",
      "Grep",
      "Search",
      "Find"
    ],
    "deny": [],
    "ask": [
      "Write(ai/**)",
      "Edit(ai/**)",
      "Write(ci/**)",
      "Edit(ci/**)"
    ]
  },
  "contextFiles": [
    "STATE.md",
    "TODO.md",
    "GEMINI.md"
  ],
  "ignorePatterns": [
    "**/.git/**",
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/.venv/**",
    "**/.pytest_cache/**",
    "**/dist/**",
    "**/build/**"
  ]
}
