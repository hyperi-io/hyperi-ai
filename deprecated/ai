#!/usr/bin/env bash
# AI Assistant Setup Tool - Bash Wrapper
#
# Standalone tool - works with or without .venv
# Prefers .venv if available, creates minimal environment if needed
#
# Run with --help for full usage instructions

set -euo pipefail

CI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$CI_DIR")"
AI_TOOL="$CI_DIR/modules/common/ai.py"
TMP_VENV="$PROJECT_ROOT/.tmp/ai-venv"
CLEANUP_VENV=false

# Determine which Python to use
if [ -f "$PROJECT_ROOT/.venv/bin/python" ]; then
    # Use existing .venv - ensure dynaconf is available
    PYTHON="$PROJECT_ROOT/.venv/bin/python"

    # Check if dynaconf is installed
    if ! "$PYTHON" -c "import dynaconf" 2>/dev/null; then
        echo "[INFO] Installing dynaconf in existing .venv..."
        if command -v uv &>/dev/null; then
            # Use uv if available (fast)
            uv pip install dynaconf pyyaml 2>/dev/null
        else
            # Fall back to pip
            "$PYTHON" -m pip install -q dynaconf pyyaml 2>/dev/null
        fi
    fi

    echo "[INFO] Using existing .venv"

else
    # Create minimal temporary venv with dynaconf
    echo "[INFO] Creating temporary environment for AI install..."
    mkdir -p "$PROJECT_ROOT/.tmp"
    python3 -m venv "$TMP_VENV"
    "$TMP_VENV/bin/pip" install -q dynaconf pyyaml 2>/dev/null
    PYTHON="$TMP_VENV/bin/python"
    CLEANUP_VENV=true
fi

# Execute Python AI tool
"$PYTHON" "$AI_TOOL" "$@"
EXIT_CODE=$?

# Cleanup temporary venv if created
if [ "$CLEANUP_VENV" = true ]; then
    rm -rf "$TMP_VENV"
    echo "[INFO] Cleaned up temporary environment"
fi

exit $EXIT_CODE
